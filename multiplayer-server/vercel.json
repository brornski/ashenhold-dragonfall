{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "fluid": true,
  "functions": {
    "api/ws.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/health" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "headers": [
    {
      "source": "/health",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
