{
  "name": "ashenhold-e2e",
  "private": true,
  "version": "5.5.0",
  "description": "Dev-only test harness for Ashenhold: Dragonfall. The GitHub Pages workflow excludes test-results from its runtime artifact; the game itself has no build step or runtime package manifest.",
  "scripts": {
    "smoke": "node e2e-smoke.cjs",
    "ai": "node ai-garrison-audit.cjs",
    "audit": "node production-audit.cjs",
    "a11y": "node accessibility-audit.cjs",
    "payload": "node payload-audit.cjs",
    "multiplayer": "node multiplayer-audit.cjs",
    "motion": "node motion-regression.cjs",
    "world": "node fixed-world-regression.cjs",
    "admin": "node admin-publish-integrity.cjs && node admin-editor-audit.cjs",
    "live": "node live-deployment-audit.cjs"
  },
  "devDependencies": {
    "axe-core": "^4.12.1",
    "playwright": "^1.61.1"
  }
}
